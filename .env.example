# ── Copier ce fichier en .env et remplacer toutes les valeurs avant tout déploiement ──

# PostgreSQL
POSTGRES_USER=vente_admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vente_intelligente
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vente_admin:change-me-strong-password@postgres:5432/vente_intelligente?schema=public

# Redis
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@redis:6379

# JWT
JWT_ACCESS_SECRET=change-me-32-chars-minimum-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-different-32-chars-minimum-secret
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3001
API_URL=http://localhost:3001
# En passant par Nginx (docker compose up), le front et l'API partagent la même origine :
# pas besoin d'élargir CORS_ORIGIN au-delà de cette origine publique.
CORS_ORIGIN=http://localhost:8080
COOKIE_SECURE=false

# Web
WEB_PORT=3000
# NEXT_PUBLIC_* sont injectées au build (voir apps/web/Dockerfile) : elles doivent pointer
# vers l'origine PUBLIQUE (Nginx), pas vers le conteneur api qui n'est jamais exposé à l'hôte.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=http://localhost:8080

# Nginx (changez ces ports s'ils sont déjà utilisés par un autre projet sur la machine)
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
