    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@plateforme/shared": "*",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
